{
  "name": "research-knowledge-vault",
  "private": true,
  "version": "0.2.0",
  "description": "Offline-first personal research and knowledge management system",
  "author": "Aaenics",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron .",
    "dist:desktop": "npm run build && electron-builder",
    "dist:mobile:init": "cap init && cap add android",
    "dist:mobile:sync": "npm run build && cap sync"
  },
  "build": {
    "appId": "com.researchvault.app",
    "productName": "Research Knowledge Vault",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "main.cjs"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "lucide-react": "^0.379.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "vite": "^5.3.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
